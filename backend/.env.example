# Plantilla de variables de entorno. Copia este archivo a `.env` y rellena los
# valores. El `.env` real está en .gitignore y NO debe commitearse.

# Puerto del servidor HTTP.
PORT=3030

# Tasas de cambio:
#   true  -> implementaciones stub (políticas en memoria y tasas fijas).
#   false -> implementaciones reales (Open Exchange Rates).
USE_STUB_DATA=true

# Open Exchange Rates: tasas de cambio históricas (endpoint historical/{fecha}).
# Sólo se usan cuando USE_STUB_DATA=false. El app_id es obligatorio en ese caso;
# consíguelo (el plan gratuito incluye datos históricos) en:
#   https://openexchangerates.org/signup/free
OPEN_EXCHANGE_RATES_APP_ID=
OPEN_EXCHANGE_RATES_BASE_URL=https://openexchangerates.org/api
